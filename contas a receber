<section id="tab-contas-receber" class="tab-section fade-in">

  <section class="panel">
    <div class="panel-head">
      <h3>Cadastrar Conta a Receber</h3>
    </div>

    <div class="form-grid">
<input id="crrCliente" placeholder="Cliente">
<input id="crrDescricao" placeholder="Descrição">
<input id="crrDocumento" placeholder="NF / FAT">
<input id="crrValor" type="number" placeholder="Valor">
<input id="crrVencimento" type="date">

<textarea id="crrObs" class="full" placeholder="Observações"></textarea>
    </div>

    <button class="btn" onclick="salvarContaReceber()">Salvar</button>
  </section>

  <section class="panel table-wrap">
    <h3>Contas a Receber</h3>
    <table>
      <thead>
        <tr>
          <th>Cliente</th>
          <th>Descrição</th>
          <th>Documento</th>
          <th>Valor</th>
          <th>Vencimento</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody id="tabelaContasReceber"></tbody>
    </table>
  </section>

</section>
